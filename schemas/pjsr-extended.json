      { "file": "pjsr/BitmapFormat.jsh", "description": "Bitmap pixel formats" },
      { "file": "pjsr/BrushStyle.jsh", "description": "Brush fill styles" },
      { "file": "pjsr/PenStyle.jsh", "description": "Pen line styles" },
      { "file": "pjsr/PenCap.jsh", "description": "Pen cap styles" },
      { "file": "pjsr/PenJoin.jsh", "description": "Pen join styles" },
      { "file": "pjsr/FillRule.jsh", "description": "Path fill rules" },
      { "file": "pjsr/CompositionOp.jsh", "description": "Graphics composition operators" },
      { "file": "pjsr/FontFamily.jsh", "description": "Font family constants" },
